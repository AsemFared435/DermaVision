# Backend API URL, including the /api/v1 prefix.
# Local development, default backend port:
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# If port 8000 is unavailable and the backend runs on 8001, use:
# VITE_API_BASE_URL=http://127.0.0.1:8001/api/v1

# Production: set VITE_API_BASE_URL in your hosting dashboard to your deployed backend URL.
# Example: VITE_API_BASE_URL=https://your-backend-domain.com/api/v1

# Firebase Config (Optional - هنستخدمه للـ Google Auth بس)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
