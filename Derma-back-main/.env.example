# Application
APP_NAME=DermaVision Backend
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# Server
HOST=127.0.0.1
PORT=8000
WORKERS=1

# Database
DATABASE_URL=sqlite:///./skin_analysis.db
# DATABASE_URL=postgresql://user:password@localhost/dbname
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_ECHO=False

# Security
SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
AUTH_REQUIRED=True
ALLOWED_HOSTS=*

# CORS
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","https://frontai.vercel.app","https://ai-front-beta-ashy.vercel.app"]

# Email / password reset
# For Gmail SMTP, use a Gmail App Password, not your normal Gmail account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_email@example.com
SMTP_USE_TLS=true
FRONTEND_BASE_URL=http://localhost:5173
# Optional: set a full reset URL. Use {token} placeholder or the backend will append ?token=...
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png"]
ALLOWED_IMAGE_MIME_TYPES=["image/jpeg","image/png"]
FILE_RETENTION_DAYS=30

# ML Model
MODEL_PATH=./app/infrastructure/ml/weights/skin_efficientnet_b4_9.pth
MODEL_DEVICE=cpu
MODEL_WARMUP=True
TOP_K_PREDICTIONS=3
DIAGNOSIS_MIN_CONFIDENCE=0.60
DIAGNOSIS_MIN_TOP2_MARGIN=0.15
DIAGNOSIS_MIN_IMAGE_QUALITY_SCORE=50

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_LOGIN_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_SIGNUP_REQUESTS=5
RATE_LIMIT_SIGNUP_WINDOW_SECONDS=60
RATE_LIMIT_FORGOT_PASSWORD_REQUESTS=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=600
RATE_LIMIT_RESET_PASSWORD_REQUESTS=5
RATE_LIMIT_RESET_PASSWORD_WINDOW_SECONDS=600
RATE_LIMIT_DIAGNOSIS_REQUESTS=10
RATE_LIMIT_DIAGNOSIS_WINDOW_SECONDS=60
RATE_LIMIT_RAG_CHAT_REQUESTS=20
RATE_LIMIT_RAG_CHAT_WINDOW_SECONDS=60

# RAG assistant
RAG_KNOWLEDGE_PATH=./app/data/rag/skin_data1.txt
RAG_VECTOR_INDEX_DIR=./app/data/rag/vector_index
RAG_TOP_K=4
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_SOURCE_SNIPPET_CHARS=500
# Optional RAG LLM settings. Leave provider/key empty to use safe local fallback generation.
# Supported providers: openai, xai, groq
RAG_LLM_PROVIDER=
OPENAI_API_KEY=
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
RAG_LLM_MODEL=llama-3.1-8b-instant
RAG_LLM_TIMEOUT_SECONDS=20
RAG_LLM_MAX_OUTPUT_TOKENS=700

# Monitoring
ENABLE_METRICS=True
HEALTH_CHECK_INTERVAL=60
